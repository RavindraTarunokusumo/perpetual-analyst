# Perpetual Analyst — environment variables
# Copy to .env and fill in real values. Never commit .env.

# Qwen Cloud (OpenAI-compatible via DashScope-intl). The substrate reads these
# from Nexus/.env at runtime; set them there. Listed here for reference.
QWEN_CLOUD_API_KEY=
LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Telegram (send-only in V1)
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# Optional: override default DB path
# ANALYST_DB_PATH=data/analyst.db

# Optional: override reports output dir
# ANALYST_REPORTS_DIR=data/reports
